<h1><%= @place["name"] %></h1>

<% if @current_user %>
  <a href="/entries/new?place_id=<%= @place["id"] %>"><h2 style="display: inline;">New Post</h2></a>
<% end %>

<br><br>

<div class="row">
  <% for entry in @entries %>
    <div class="col-12 col-md-4 mb-4">
      <div class="border rounded p-3">
        <h3><%= entry["title"] %></h3>
        <p class="text-muted small"><%= entry["occurred_on"] %></p>
        <% if entry.image.attached? %>
          <%= image_tag entry.image, style: "width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 4px;" %>
        <% end %>
        <p><%= entry["description"] %></p>
      </div>
    </div>
  <% end %>
</div>

<p>
  <a href="/places">Back to All Places</a>
</p>
