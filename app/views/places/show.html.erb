<h1><%= @place["name"] %></h1>

<% if @current_user %>
  <a href="/entries/new?place_id=<%= @place["id"] %>"><h2 style="display: inline;">New Post</h2></a>
<% end %>

<br><br>

<div style="display: flex; flex-wrap: wrap; gap: 16px;">
  <% for entry in @entries %>
    <div style="width: calc(33.333% - 12px); box-sizing: border-box; border: 1px solid #ddd; padding: 12px; border-radius: 6px;">
      <h3 style="margin: 0 0 4px 0;"><%= entry["title"] %></h3>
      <p style="margin: 0 0 8px 0; color: #888; font-size: 0.85em;"><%= entry["occurred_on"] %></p>
      <% if entry.image.attached? %>
        <%= image_tag entry.image, style: "width: 100%; aspect-ratio: 1 / 1; object-fit: cover; border-radius: 4px;" %>
      <% end %>
      <p style="margin: 8px 0 0 0;"><%= entry["description"] %></p>
    </div>
  <% end %>
</div>

<p>
  <a href="/places">Back to All Places</a>
</p>
